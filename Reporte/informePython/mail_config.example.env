# Copiar a mail_config.env y completar.
# En cPanel suele funcionar SMTP localhost:25 sin usuario/clave.

SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_TLS=0

# Remitente: usar un mail del mismo dominio del hosting (ej. posmoon.com.ar)
MAIL_FROM=informe@posmoon.com.ar
MAIL_TO=moondesarrollos@gmail.com
